# Copier vers .env.local ou variables Vercel (sans guillemets parasites ni \r\n dans les valeurs).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Clé anon ou publishable (Dashboard → API) — requis pour GET/POST /api/tickets-rls
SUPABASE_ANON_KEY=
SUPABASE_APP_STATE_TABLE=app_state
# Recopie dia_tickets → app_state.tickets après chaque mutation (stats dashboard)
TICKETS_DUAL_WRITE_APP_STATE=1

# --- Étape 1 : sécuriser les écritures legacy (hors /api/tickets-rls) ---
# Recommandé sur Vercel : Production, Preview et Development — bloque POST/PUT/DELETE /api/tickets (legacy) ; utiliser /api/tickets-rls + JWT.
DIATECH_BLOCK_LEGACY_TICKET_WRITES=1
# Optionnel : si défini, les autres mutations /api legacy exigent le header X-DiaTech-Write-Key (ne pas exposer cette valeur au front).
# DIATECH_LEGACY_WRITE_KEY=

# --- Admin Pro : invitations, mots de passe, audit (table dia_admin_audit) ---
# URL absolue de retour après clic sur le lien d’invitation (ex. https://votre-app.vercel.app/login.html)
# DIATECH_INVITE_REDIRECT_URL=
# Longueur minimale des mots de passe créés par l’admin (défaut 12 ; min 8 côté code)
# DIATECH_MIN_ADMIN_PASSWORD_LENGTH=12
