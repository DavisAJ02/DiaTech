# Copier vers .env.local ou variables Vercel (sans guillemets parasites ni \r\n dans les valeurs).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Clé anon ou publishable (Dashboard → API) — requis pour GET/POST /api/tickets-rls
SUPABASE_ANON_KEY=
SUPABASE_APP_STATE_TABLE=app_state
# Recopie dia_tickets → app_state.tickets après chaque mutation (stats dashboard)
TICKETS_DUAL_WRITE_APP_STATE=1
